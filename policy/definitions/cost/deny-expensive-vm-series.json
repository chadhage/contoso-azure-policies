{
  "name": "contoso-deny-expensive-vm-series",
  "type": "Microsoft.Authorization/policyDefinitions",
  "properties": {
    "displayName": "Deny expensive GPU, HPC, and large memory-optimized virtual machine series",
    "policyType": "Custom",
    "mode": "Indexed",
    "description": "Blocks high-cost GPU (N-series), HPC (H-series), and large memory-optimized (M-series) virtual machine families unless explicitly approved, preventing accidental large spend. The blocked families are configurable via the blockedSkuPrefixes parameter. Supports the Cost Optimization pillar of the Well-Architected Framework.",
    "metadata": {
      "version": "1.0.0",
      "category": "Compute",
      "wafPillar": "Cost",
      "organization": "Contoso"
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [ "Audit", "Deny", "Disabled" ],
        "defaultValue": "Deny"
      },
      "blockedSkuPrefixes": {
        "type": "Array",
        "metadata": {
          "displayName": "Blocked SKU prefixes",
          "description": "VM SKU name prefixes to block (case-insensitive match on start of name)."
        },
        "defaultValue": [
          "Standard_N",
          "Standard_H",
          "Standard_M"
        ]
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Compute/virtualMachines"
          },
          {
            "count": {
              "value": "[parameters('blockedSkuPrefixes')]",
              "name": "prefix",
              "where": {
                "value": "[toLower(field('Microsoft.Compute/virtualMachines/sku.name'))]",
                "like": "[toLower(concat(current('prefix'), '*'))]"
              }
            },
            "greater": 0
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}
