{
  "name": "contoso-allowed-locations-rg",
  "type": "Microsoft.Authorization/policyDefinitions",
  "properties": {
    "displayName": "Allowed locations for resource groups",
    "policyType": "Custom",
    "mode": "All",
    "description": "Restricts the regions into which resource groups can be created to Contoso's approved data-residency regions. Complements the resource-level allowed-locations policy (which uses Indexed mode and does not evaluate resource groups). Supports the Governance / Operational Excellence pillar of the Well-Architected Framework.",
    "metadata": {
      "version": "1.0.0",
      "category": "General",
      "wafPillar": "Governance",
      "organization": "Contoso"
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [ "Audit", "Deny", "Disabled" ],
        "defaultValue": "Deny"
      },
      "allowedLocations": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed locations",
          "description": "The list of permitted Azure regions for resource groups.",
          "strongType": "location"
        },
        "defaultValue": [ "eastus", "westus3", "westeurope" ]
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Resources/subscriptions/resourceGroups"
          },
          {
            "field": "location",
            "notIn": "[parameters('allowedLocations')]"
          },
          {
            "field": "location",
            "notEquals": "global"
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}
