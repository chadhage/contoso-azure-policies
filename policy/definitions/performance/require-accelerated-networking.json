{
  "name": "contoso-require-accelerated-networking",
  "type": "Microsoft.Authorization/policyDefinitions",
  "properties": {
    "displayName": "Network interfaces should have accelerated networking enabled",
    "policyType": "Custom",
    "mode": "Indexed",
    "description": "Audits network interfaces that do not have accelerated networking enabled, which lowers latency and jitter and increases packets-per-second on supported VM sizes. Supports the Performance Efficiency pillar of the Well-Architected Framework.",
    "metadata": {
      "version": "1.0.0",
      "category": "Network",
      "wafPillar": "Performance",
      "organization": "Contoso"
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect"
        },
        "allowedValues": [ "Audit", "Disabled" ],
        "defaultValue": "Audit"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Network/networkInterfaces"
          },
          {
            "field": "Microsoft.Network/networkInterfaces/enableAcceleratedNetworking",
            "notEquals": "true"
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}
