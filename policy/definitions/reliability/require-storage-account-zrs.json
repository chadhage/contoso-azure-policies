{
  "name": "contoso-require-storage-account-zrs",
  "type": "Microsoft.Authorization/policyDefinitions",
  "properties": {
    "displayName": "Storage accounts should use zone- or geo-redundant replication",
    "policyType": "Custom",
    "mode": "Indexed",
    "description": "Enforces that storage accounts use a resilient SKU (ZRS, GZRS, GRS, or RAGRS) so data survives datacenter or region failures. Supports the Reliability pillar of the Well-Architected Framework.",
    "metadata": {
      "version": "1.0.0",
      "category": "Storage",
      "wafPillar": "Reliability",
      "organization": "Contoso"
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [ "Audit", "Deny", "Disabled" ],
        "defaultValue": "Audit"
      },
      "allowedSkus": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed redundant SKUs",
          "description": "Storage SKUs considered resilient."
        },
        "defaultValue": [
          "Standard_ZRS",
          "Standard_GRS",
          "Standard_RAGRS",
          "Standard_GZRS",
          "Standard_RAGZRS",
          "Premium_ZRS"
        ]
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Storage/storageAccounts"
          },
          {
            "not": {
              "field": "Microsoft.Storage/storageAccounts/sku.name",
              "in": "[parameters('allowedSkus')]"
            }
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}
