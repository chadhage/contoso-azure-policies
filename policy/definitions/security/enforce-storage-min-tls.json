{
  "name": "contoso-enforce-storage-min-tls",
  "type": "Microsoft.Authorization/policyDefinitions",
  "properties": {
    "displayName": "Storage accounts should enforce a minimum TLS version of 1.2",
    "policyType": "Custom",
    "mode": "Indexed",
    "description": "Ensures storage accounts reject connections using TLS versions older than 1.2. Supports Modify to auto-remediate. Supports the Security pillar of the Well-Architected Framework.",
    "metadata": {
      "version": "1.0.0",
      "category": "Storage",
      "wafPillar": "Security",
      "organization": "Contoso"
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [ "Audit", "Deny", "Modify", "Disabled" ],
        "defaultValue": "Modify"
      },
      "minimumTlsVersion": {
        "type": "String",
        "metadata": {
          "displayName": "Minimum TLS version",
          "description": "The minimum accepted TLS version."
        },
        "allowedValues": [ "TLS1_2", "TLS1_3" ],
        "defaultValue": "TLS1_2"
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Storage/storageAccounts"
          },
          {
            "field": "Microsoft.Storage/storageAccounts/minimumTlsVersion",
            "notEquals": "[parameters('minimumTlsVersion')]"
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "roleDefinitionIds": [
            "/providers/Microsoft.Authorization/roleDefinitions/17d1049b-9a84-46fb-8f53-869881c3d3ab"
          ],
          "conflictEffect": "audit",
          "operations": [
            {
              "operation": "addOrReplace",
              "field": "Microsoft.Storage/storageAccounts/minimumTlsVersion",
              "value": "[parameters('minimumTlsVersion')]"
            }
          ]
        }
      }
    }
  }
}
