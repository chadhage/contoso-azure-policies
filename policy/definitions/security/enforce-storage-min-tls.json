{
  "name": "contoso-enforce-storage-min-tls",
  "type": "Microsoft.Authorization/policyDefinitions",
  "properties": {
    "displayName": "Storage accounts should enforce a minimum TLS version of 1.2",
    "policyType": "Custom",
    "mode": "Indexed",
    "description": "Flags storage accounts whose minimum TLS version is below the required floor (TLS 1.2). Versions at or above the floor (including TLS 1.3) are compliant. Modify raises non-compliant accounts to the floor and never downgrades a higher version. Supports the Security pillar of the Well-Architected Framework.",
    "metadata": {
      "version": "1.0.0",
      "category": "Storage",
      "wafPillar": "Security",
      "organization": "Contoso"
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Enable or disable the execution of the policy."
        },
        "allowedValues": [ "Audit", "Deny", "Modify", "Disabled" ],
        "defaultValue": "Audit"
      },
      "minimumTlsVersion": {
        "type": "String",
        "metadata": {
          "displayName": "Minimum TLS version",
          "description": "The floor that Modify sets on non-compliant accounts."
        },
        "allowedValues": [ "TLS1_2", "TLS1_3" ],
        "defaultValue": "TLS1_2"
      },
      "compliantTlsVersions": {
        "type": "Array",
        "metadata": {
          "displayName": "Compliant TLS versions",
          "description": "Minimum TLS versions considered at or above the required floor. Accounts set to any of these (for example TLS1_3) are compliant and are never modified."
        },
        "defaultValue": [ "TLS1_2", "TLS1_3" ]
      }
    },
    "policyRule": {
      "if": {
        "allOf": [
          {
            "field": "type",
            "equals": "Microsoft.Storage/storageAccounts"
          },
          {
            "field": "Microsoft.Storage/storageAccounts/minimumTlsVersion",
            "notIn": "[parameters('compliantTlsVersions')]"
          }
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "roleDefinitionIds": [
            "/providers/Microsoft.Authorization/roleDefinitions/17d1049b-9a84-46fb-8f53-869881c3d3ab"
          ],
          "conflictEffect": "audit",
          "operations": [
            {
              "operation": "addOrReplace",
              "field": "Microsoft.Storage/storageAccounts/minimumTlsVersion",
              "value": "[parameters('minimumTlsVersion')]"
            }
          ]
        }
      }
    }
  }
}
